datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model ClientCard {
  id         Int             @id @default(autoincrement())
  clientName String
  websiteUrl String
  imageUrl   String
  tags       ClientCardTag[]
}

model Tag {
  id           Int              @id @default(autoincrement())
  name         String?
  translations TagTranslation[]
  clientCards  ClientCardTag[]
}

model TagTranslation {
  id           Int    @id @default(autoincrement())
  languageCode String
  name         String
  tag          Tag    @relation(fields: [tagId], references: [id])
  tagId        Int
}

model ClientCardTag {
  clientCard   ClientCard @relation(fields: [clientCardId], references: [id])
  clientCardId Int
  tag          Tag        @relation(fields: [tagId], references: [id])
  tagId        Int

  @@id([clientCardId, tagId])
}
